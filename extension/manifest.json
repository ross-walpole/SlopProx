{
  "manifest_version": 3,
  "name": "SlopProx",
  "version": "1.0.0",
  "description": "Detects and hides AI-generated text, images, and YouTube videos as you browse. All processing stays on your machine.",
  "homepage_url": "https://slopprox.com",
  "permissions": ["storage", "declarativeNetRequest", "declarativeNetRequestFeedback"],
  "host_permissions": [
    "http://127.0.0.1:8083/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      { "id": "ad-block", "enabled": true, "path": "ad-rules.json" }
    ]
  },
  "icons": {
    "16":  "icons/icon-16.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "slopprox@rosswalpole.com",
      "strict_min_version": "128.0",
      "data_collection_permissions": {
        "required": [],
        "optional": []
      }
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "SlopProx",
    "default_icon": {
      "16":  "icons/icon-16.png",
      "48":  "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
