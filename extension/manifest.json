{
  "manifest_version": 3,
  "name": "AI Slop Filter",
  "version": "1.9.0",
  "description": "Detect and blur AI-generated text and images on any website. Requires the AI Slop Filter desktop app.",
  "permissions": ["storage"],
  "host_permissions": [
    "http://127.0.0.1:8083/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Slop Filter"
  }
}
