{
  "name": "ai-slop-filter",
  "author": "Ross Walpole",
  "version": "1.0.0",
  "description": "SlopProx AI Slop Filter — Reclaim the internet from AI-generated slop.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.ai.slopfilter",
    "productName": "AI Slop Filter",
    "win": {
      "target": "nsis",
      "icon": "icon.png",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "ross-walpole",
      "repo": "SlopProx",
      "private": true,
      "token": "your_github_token_here"
    },
    "asarUnpack": [
      "**/node_modules/sharp/**"
    ]
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "cheerio": "^1.0.0-rc.12",
    "electron-updater": "^6.8.3",
    "mockttp": "^4.2.3",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "electron": "^41.0.4",
    "electron-builder": "^25.1.8"
  }
}
